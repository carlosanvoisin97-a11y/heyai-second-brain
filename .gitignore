.obsidian/workspace*
.obsidian/cache/
.trash/

# Office / LibreOffice — lock file temporanei
~$*
.~lock.*#

# Python — virtualenv e cache
.venv/
__pycache__/
*.pyc

# Node
node_modules/

# Editor / backup / temp
.vscode/
*.swp
*.swo
*.tmp
*~

# Raw transcript dumps — dati grezzi clienti (PII): NON sul cloud, ingest selettivo nel vault (F2)
00 - Inbox/_DA_DOWNLOADS_2026-06-06/
_DA_DOWNLOADS_*/
